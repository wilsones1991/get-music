# ---- qBittorrent (on the Mac mini, reached over WireGuard) ----
# 10.8.0.2 is the Mac mini's WireGuard tunnel IP. Web UI is on host port 8090
# (8080 was already taken on the mini by another service). For local testing on
# the mini itself use http://127.0.0.1:8090. Credentials are in
# ~/qbt-vpn/qbt-credentials.txt.
QBITTORRENT_URL=http://10.8.0.2:8090
QBITTORRENT_USER=admin
QBITTORRENT_PASS=see_~/qbt-vpn/qbt-credentials.txt

# Stall watchdog: if a torrent makes no download progress for this many minutes
# while still trying (metaDL/stalledDL/etc.), it has no reachable seeders — the
# app deletes it (with any partial files) and logs a "no seeders" failure that
# shows in the recent-downloads table. Default 30. Never touches seeding, paused,
# or drive-disconnected torrents.
TORRENT_STALL_TIMEOUT_MIN=30

# ---- Prowlarr (optional second search source, esp. for music) ----
# Self-hosted indexer manager on the Mac mini, reached over WireGuard. Aggregates
# many torrent indexers behind one API and lets searches be scoped to the Audio
# category (the "🎵 music only" checkbox). Leave unset to search Snowfl only.
# API key: Prowlarr → Settings → General → Security → API Key. Default port 9696.
# Run it behind gluetun like qBittorrent so its indexer traffic also uses the VPN.
PROWLARR_URL=http://10.8.0.2:9696
PROWLARR_API_KEY=your_prowlarr_api_key
# Prowlarr hands back http proxy download links, not raw magnets, and qBittorrent
# fetches them itself — but qBittorrent runs inside gluetun's VPN namespace and
# can't reach PROWLARR_URL's host (the WireGuard IP). Since it SHARES Prowlarr's
# namespace, it reaches Prowlarr on localhost. The app rewrites those links to
# 127.0.0.1 (same port) by default, which is correct for this setup. Override only
# if qBittorrent reaches Prowlarr at a different address.
# PROWLARR_QBIT_URL=http://127.0.0.1:9696

# ---- gluetun control API (optional VPN status indicator / download gating) ----
# Leave unset to disable the VPN check. When set, downloads are blocked if the
# tunnel is reported down. (The publicip route is exposed without auth via
# ~/qbt-vpn/gluetun-auth/config.toml.)
GLUETUN_CONTROL_URL=http://10.8.0.2:8000

# ---- Jellyfin (library refresh after a download) ----
JELLYFIN_URL=http://10.8.0.2:8096
JELLYFIN_API_KEY=your_jellyfin_api_key

# ---- MeTube (paste a YouTube/other link → MP3 or video) ----
# Self-hosted yt-dlp service on the Mac mini, reached over WireGuard. Leave unset
# to hide the feature (the /yt endpoints return 503). Unlike torrents, these
# downloads do NOT go through Mullvad. See docs/macmini-setup.md.
METUBE_URL=http://10.8.0.2:8081

# ---- Download directories as qBittorrent (in its container) sees them ----
MEDIA_MOVIES=/downloads/movies
MEDIA_TV=/downloads/tvshows
MEDIA_MUSIC=/downloads/music
MEDIA_GENERAL=/downloads/torrents

# ---- Google SSO ----
# BASE_URL is the public origin of this app (used for the OAuth redirect URI).
BASE_URL=https://get-music.example.com
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# ---- Sessions & access control ----
SESSION_SECRET=generate_a_long_random_string
# Comma-separated bootstrap admins. Always allowed, always admin, cannot be
# removed from the UI. Seeds the allowlist on first run.
ADMIN_EMAILS=you@example.com
# Persistent directory for users.json and session files (mount a volume here).
DATA_DIR=/data

# ---- Misc ----
# Set in production so secure cookies + proxy trust are enabled.
NODE_ENV=production
TMDB_KEY=your_tmdb_api_key_here
